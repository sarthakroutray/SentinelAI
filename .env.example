# ─────────────────────────────────────────────────────────────────────────────
# SentinelAI — Environment Configuration
#
# Copy this file to .env and fill in ALL required fields before starting.
#   cp .env.example .env
#
# REQUIRED fields have no default and MUST be set before production deployment.
# Optional fields have safe defaults suitable for local development.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Generate a strong password: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=REPLACE_ME_BEFORE_DEPLOYMENT
POSTGRES_DB=sentinelai

# Set automatically by docker-compose from the vars above — override only for
# external Postgres (e.g. Supabase):
# DATABASE_URL=postgresql+asyncpg://sentinel:PASSWORD@db:5432/sentinelai

# ── Redis (REQUIRED in production) ───────────────────────────────────────────
# Set automatically by docker-compose. Override for managed Redis (Redis Cloud, Upstash):
# REDIS_URL=redis://localhost:6379/0

# ── API Authentication (REQUIRED for production) ──────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Leaving this empty disables authentication — ONLY acceptable in local dev.
API_KEY=REPLACE_ME_BEFORE_DEPLOYMENT

# ── CORS Origins ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser requests.
# Default is localhost:3000 (dev only). Set to your actual frontend URL in prod.
# CORS_ORIGINS=https://sentinel.yourdomain.com

# ── Security Mode ─────────────────────────────────────────────────────────────
# NEVER set DEBUG=true in production — it disables the API_KEY startup gate.
DEBUG=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum log ingestion requests per minute per IP address.
# RATE_LIMIT_LOGS_PER_MINUTE=300

# ── Queue Backpressure ────────────────────────────────────────────────────────
# Maximum number of messages allowed in the Redis queue before rejecting ingest.
# MAX_QUEUE_DEPTH=50000

# ── Anomaly Detection Tunables ────────────────────────────────────────────────
# MODEL_RETRAIN_INTERVAL=200         # Baseline samples required to trigger retrain
# RETRAIN_COOLDOWN_SECONDS=300       # Minimum seconds between retrains
# ISOLATION_CONTAMINATION=0.05       # Expected fraction of anomalies in training data
# ANOMALY_THRESHOLD_LOW=0.2
# ANOMALY_THRESHOLD_MEDIUM=0.4
# ANOMALY_THRESHOLD_HIGH=0.7

# ── Scoring Weights (must sum to 1.0) ─────────────────────────────────────────
# RULE_WEIGHT=0.5
# STAT_WEIGHT=0.3
# ISO_WEIGHT=0.2
