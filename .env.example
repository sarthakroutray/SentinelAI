# Supabase PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Optional
DEBUG=false
REDIS_URL=redis://localhost:6379/0

# Authentication – leave empty to disable (dev mode)
API_KEY=

# IsolationForest retrain cooldown (seconds between retrains)
RETRAIN_COOLDOWN_SECONDS=300
